{
  "kind": "collectionType",
  "collectionName": "realisations_all",
  "info": {
    "singularName": "realisations",
    "pluralName": "realisations-all",
    "displayName": "Réalisations",
    "description": "Réalisations de Solitek"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "extrait": {
      "type": "text",
      "required": true
    },
    "datePublication": {
      "type": "datetime",
      "required": true
    },
    "categorie": {
      "type": "enumeration",
      "enum": [
        "Photovoltaique",
        "Chauffage",
        "Climatisation",
        "Ventilation",
        "Electricite",
        "Entretien"
      ],
      "required": true
    },
    "imageCouverture": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "contenu": {
      "type": "dynamiczone",
      "components": [
        "content-blocks.paragraphe",
        "content-blocks.image",
        "content-blocks.video",
        "content-blocks.image-et-texte",
        "content-blocks.deux-colonnes",
        "content-blocks.galerie",
        "content-blocks.citation",
        "content-blocks.callout"
      ],
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "videoCouverture": {
      "type": "string"
    },
    "afficherControlesVideo": {
      "type": "boolean",
      "default": false
    },
    "misEnAvant": {
      "type": "boolean",
      "default": false
    }
  }
}
